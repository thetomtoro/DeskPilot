generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Document {
  id         String   @id @default(cuid())
  filename   String   @unique
  title      String
  chunkCount Int      @default(0)
  ingestedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Conversation {
  id        String    @id @default(cuid())
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant"
  content        String
  sources        String?      // JSON array of source doc names
  confidence     Float?
  latencyMs      Int?
  createdAt      DateTime     @default(now())
}

model Ticket {
  id         String    @id @default(cuid())
  question   String
  aiAnswer   String?
  confidence Float
  status     String    @default("open") // "open" | "assigned" | "resolved"
  category   String?
  priority   String?   // "low" | "medium" | "high"
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  resolution String?
}

model EvalRun {
  id            String       @id @default(cuid())
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  totalCases    Int
  overallScores String?      // JSON object with aggregate metrics
  results       EvalResult[]
}

model EvalResult {
  id               String  @id @default(cuid())
  evalRunId        String
  evalRun          EvalRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  testCaseId       String
  question         String
  retrievedSources String? // JSON array
  expectedSource   String
  retrievalHit     Boolean
  answerCorrect    Boolean
  confidence       Float
  latencyMs        Int
}
